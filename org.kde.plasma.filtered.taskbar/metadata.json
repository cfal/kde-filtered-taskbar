{
    "KPackageStructure": "Plasma/Applet",
    "KPlugin": {
        "Authors": [
            {
                "Email": "hein@kde.org",
                "Name": "Eike Hein"
            },
            {
                "Name": "André Klein"
            }
        ],
        "Category": "Windows and Tasks",
        "Comment": "Based on the KDE Plasma Task Manager by Eike Hein, heavily modified by André Klein to add application filtering",
        "Description": "A minimal, heavily modified version of the KDE Task Manager that filters applications to show only specified ones",
        "EnabledByDefault": true,
        "Icon": "preferences-system-windows",
        "Id": "org.kde.plasma.filtered.taskbar",
        "License": "GPL-2.0+",
        "Name": "Filtered Taskbar",
        "Website": "https://userbase.kde.org/Plasma/Tasks"
    },
    "X-Plasma-API-Minimum-Version": "6.0",
    "X-Plasma-MainScript": "ui/main.qml",
    "X-Plasma-Provides": [
        "org.kde.plasma.multitasking"
    ]
}
